# Ignore everything by default.
*

# Keep the ignore rules versioned.
!.gitignore

# Keep the project README.
!README.md

# Keep notebook images.
!images/
!images/**

# Keep utility scripts.
!scripts/
!scripts/*.py
# Local maintenance helper; end users never need to run it.
scripts/make_colab_ready.py

# Keep the main task notebooks.
!notebooks/
!notebooks/segmentation.ipynb
!notebooks/detection.ipynb
!notebooks/detection_yolo.ipynb
!notebooks/classification.ipynb


# Keep environment definitions.
!environment/
!environment/environment.yml
!environment/requirements.txt
